FROM python:3.10
WORKDIR /app

# 先复制依赖文件，利用 Docker 层缓存避免重复安装
COPY requirements.txt ./

# 安装依赖
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt -i https://mirrors.aliyun.com/pypi/simple

# 再复制源代码
COPY . .

# 暴露端口
EXPOSE 9099

# 启动命令
CMD ["python", "app.py", "--env=dockerpg"]