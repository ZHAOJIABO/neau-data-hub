{
  "_schema_version": "1.0.0",
  "_description": "Test 1: Time-series upstream discharge (ramp from 10 to 50 m3/s), zero downstream outflow",

  "channel": {
    "L":           5000.0,
    "nx":          51,
    "b":           5.0,
    "m":           1.5,
    "n_Manning":   0.025,
    "S0":          0.0003,
    "Q_initial":   10.0,
    "tf":          3600.0,
    "dt":          30.0,
    "g":           9.81,
    "tolerance":   1e-6,
    "Q_upstream_series": [10, 20, 30, 40, 50, 50, 40, 30, 20, 10],
    "t_series":        [0, 400, 800, 1200, 1600, 2000, 2400, 2800, 3200, 3600]
  },

  "solver": {
    "theta":          0.5,
    "tolerance":      1e-6,
    "max_iterations": 100
  },

  "branches": [
    { "x_position": 1000.0, "Q_offtake": 2.0, "spread_cells": 2 },
    { "x_position": 2500.0, "Q_offtake": 2.0, "spread_cells": 2 },
    { "x_position": 4000.0, "Q_offtake": 2.0, "spread_cells": 2 }
  ]
}
